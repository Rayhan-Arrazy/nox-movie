{
  "info": {
    "_postman_id": "cineverse-api-collection-v1",
    "name": "CineVerse API",
    "description": "Complete API collection for CineVerse movie streaming platform.\n\n## Setup\n1. Set the `base_url` variable to your server (default: http://localhost:8080)\n2. Set `tmdb_token` to your TMDB Read Access Token from https://www.themoviedb.org/settings/api\n3. Run the **Auth / Login (Admin)** request first to get a session cookie\n\n## API Groups\n- **Auth** — Login, Register, Logout\n- **Local Movies API** — CineVerse's own movie database\n- **TMDB Proxy API** — Proxied TMDB endpoints (requires TMDB token in .env)\n- **Admin** — Movie CRUD and user management (requires admin session)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",   "value": "http://localhost:8080",              "type": "string" },
    { "key": "tmdb_token", "value": "YOUR_TMDB_READ_ACCESS_TOKEN_HERE",  "type": "string" },
    { "key": "movie_id",   "value": "1",                                  "type": "string" },
    { "key": "tmdb_movie_id", "value": "550",                             "type": "string", "description": "TMDB movie ID (550 = Fight Club)" },
    { "key": "user_id",    "value": "2",                                  "type": "string" },
    { "key": "movie_slug", "value": "neon-nights",                        "type": "string" }
  ],
  "item": [

    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Login (Admin)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Login successful', () => pm.response.to.have.status(200));",
            "pm.test('Redirected to admin or home', () => { const url = pm.response.url; pm.expect(url).to.include('localhost'); });"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "email",    "value": "admin@cineverse.com" },
                { "key": "password", "value": "admin123" }
              ]
            },
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] },
            "description": "Login as admin. Session cookie is automatically stored by Postman."
          }
        },
        {
          "name": "Login (Client)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "email",    "value": "john@example.com" },
                { "key": "password", "value": "client123" }
              ]
            },
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] },
            "description": "Login as a regular client user."
          }
        },
        {
          "name": "Register New User",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Registration returns redirect', () => pm.expect([200, 302, 303]).to.include(pm.response.code));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "name",             "value": "Postman User" },
                { "key": "email",            "value": "postman@example.com" },
                { "key": "password",         "value": "postman123" },
                { "key": "confirm_password", "value": "postman123" }
              ]
            },
            "url": { "raw": "{{base_url}}/register", "host": ["{{base_url}}"], "path": ["register"] },
            "description": "Register a new client account."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/logout", "host": ["{{base_url}}"], "path": ["logout"] },
            "description": "Destroy the current session and redirect to login."
          }
        }
      ]
    },

    {
      "name": "🎬 Local Movies API",
      "description": "CineVerse's own movie database endpoints.",
      "item": [
        {
          "name": "Get All Movies",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Response has data array', () => { const json = pm.response.json(); pm.expect(json.data).to.be.an('array'); });",
            "pm.test('Status is success', () => pm.expect(pm.response.json().status).to.eql('success'));",
            "if (pm.response.json().data.length > 0) { pm.collectionVariables.set('movie_id', pm.response.json().data[0].id); pm.collectionVariables.set('movie_slug', pm.response.json().data[0].slug); }"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/movies", "host": ["{{base_url}}"], "path": ["api", "movies"] },
            "description": "Returns all movies in the local database."
          }
        },
        {
          "name": "Get All Movies (with limit)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/movies?limit=5",
